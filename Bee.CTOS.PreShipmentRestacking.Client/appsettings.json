{
  // Serilog 日志框架的详细配置（功能更强大的第三方日志库）
  "Serilog": {
    // Serilog 最小日志级别配置
    "MinimumLevel": {
      // Serilog 默认日志级别为 Debug
      "Default": "Debug",
      // 针对特定命名空间/组件的日志级别覆盖配置
      "Override": {
        // 覆盖 Microsoft 组件的日志级别为 Warning
        "Microsoft": "Warning",
        // 覆盖 Orleans 框架的日志级别为 Debug
        "Orleans": "Debug"
      }
    },
    // 日志输出目标配置（将日志写入到不同的地方）
    "WriteTo": [
      {
        // 第一个输出目标：控制台（Console）
        "Name": "Console",
        "Args": {
          // 控制台日志输出模板：包含时间戳、日志级别、日志消息、异常信息
          // {Timestamp:HH:mm:ss}：时间戳（时分秒）
          // {Level:u3}：日志级别（3个字符的大写缩写，如 INF/WRN/ERR）
          // {Message:lj}：日志消息（l=字面量，j=结构化）
          // {NewLine}{Exception}：换行后输出异常信息（如果有）
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        // 第二个输出目标：文件（File）
        "Name": "File",
        "Args": {
          // 日志文件路径：logs 文件夹下，文件名为 dev-orleans-silo- 开头
          // 会自动拼接日期（如 dev-orleans-silo-20260314.log）
          "path": "logs/dev-orleans-silo-.log",
          // 日志文件滚动策略：按天滚动（每天生成一个新的日志文件）
          "rollingInterval": "Day"
        }
      }
    ]
  }
}